#!/usr/bin/env bash

# shadow-mirror: The CLI engine for Jungian shadow integration
# Adheres to the "Constraint-to-Catalyst" philosophy for low-bandwidth operation.

set -euo pipefail

# --- CONFIGURATION ---
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/shadow_mirror"
RAW_DIR="${CONFIG_DIR}/raw"
SYNTH_DIR="${CONFIG_DIR}/synthesis"
LOGS_DIR="${CONFIG_DIR}/logs"
DATA_DIR="${CONFIG_DIR}/data"

# Ensure directories exist
mkdir -p "${RAW_DIR}" "${SYNTH_DIR}" "${LOGS_DIR}" "${DATA_DIR}"

# --- HELPER FUNCTIONS ---

get_energy_state() {
    echo "🪞 Spoons Check. [1] Green [2] Yellow [3] Red"
    
    local state=""
    while [[ ! "$state" =~ ^[1-3]$ ]]; do
        read -r -n 1 -p "> " state
        echo "" # new line after raw input
    done
    
    # Export state so it can be passed to python logger
    case "$state" in
        1) export SPOONS="Green" ;;
        2) export SPOONS="Yellow" ;;
        3) export SPOONS="Red" ;;
    esac
}

print_usage() {
    echo ""
    echo "Shadow Mirror 🪞"
    echo "An AI-mediated cognitive prosthesis for shadow integration."
    echo "Zero judgment. Zero pressure."
    echo ""
    echo "Usage:"
    echo "  shadow-mirror --entry    # Paste a raw thought via Superwhisper"
    echo "  shadow-mirror --review   # Search and review past entries"
    echo "  shadow-mirror --patterns # Name recurring themes on a Green day"
    echo "  shadow-mirror --status   # See what is mirrored or waiting"
    echo "  shadow-mirror --retry    # Re-mirror entries that need another pass"
    echo "  shadow-mirror --help     # Show this screen"
    echo ""
}

notify_failed_entries() {
    local failed_count
    failed_count=$(find "$LOGS_DIR" -maxdepth 1 -type f -name "failed_*" -print 2>/dev/null | wc -l | tr -d ' ')

    if [[ "$failed_count" -eq 1 ]]; then
        echo "1 earlier entry is waiting to be re-mirrored. Run: shadow-mirror --retry"
    elif [[ "$failed_count" -gt 1 ]]; then
        echo "$failed_count earlier entries are waiting to be re-mirrored. Run: shadow-mirror --retry"
    fi
}

show_status() {
    local processed pending failed raw_file timestamp
    processed=$(find "$SYNTH_DIR" -maxdepth 1 -type f -name "entry_*.md" -print 2>/dev/null | wc -l | tr -d ' ')
    failed=$(find "$LOGS_DIR" -maxdepth 1 -type f -name "failed_*" -print 2>/dev/null | wc -l | tr -d ' ')
    pending=0

    for raw_file in "$RAW_DIR"/entry_*.txt; do
        [[ -e "$raw_file" ]] || continue
        timestamp="${raw_file##*/entry_}"
        timestamp="${timestamp%.txt}"
        if [[ ! -f "$SYNTH_DIR/entry_${timestamp}.md" && ! -f "$LOGS_DIR/failed_${timestamp}" ]]; then
            pending=$((pending + 1))
        fi
    done

    echo "$processed mirrored, $pending still processing, $failed waiting to be re-mirrored."
}

launch_processing() {
    local timestamp="$1"
    local spoons="$2"
    local bin_dir script_dir venv_python

    bin_dir="$(script_directory)"
    script_dir="${bin_dir}/../scripts"
    venv_python="${bin_dir}/../venv/bin/python"
    nohup "$venv_python" "$script_dir/process.py" "$timestamp" "$spoons" >> "$LOGS_DIR/process.log" 2>&1 &
}

script_directory() {
    local source="${BASH_SOURCE[0]}"
    local source_dir

    while [[ -h "$source" ]]; do
        source_dir="$(cd -P "$(dirname "$source")" && pwd)"
        source="$(readlink "$source")"
        [[ "$source" == /* ]] || source="${source_dir}/${source}"
    done

    cd -P "$(dirname "$source")" && pwd
}

retry_failed_entries() {
    local marker timestamp
    local markers=("$LOGS_DIR"/failed_*)

    if [[ ! -e "${markers[0]}" ]]; then
        echo "Nothing is waiting to be re-mirrored."
        return
    fi

    for marker in "${markers[@]}"; do
        timestamp="${marker##*/failed_}"
        launch_processing "$timestamp" "Yellow"
    done

    if [[ ${#markers[@]} -eq 1 ]]; then
        echo "Re-mirroring 1 earlier entry."
    else
        echo "Re-mirroring ${#markers[@]} earlier entries."
    fi
}

show_patterns() {
    get_energy_state

    if [[ "$SPOONS" != "Green" ]]; then
        echo "🪞 The mirror is holding everything safely. Patterns will be here when you have more room."
        return
    fi

    local bin_dir script_dir venv_python
    bin_dir="$(script_directory)"
    script_dir="${bin_dir}/../scripts"
    venv_python="${bin_dir}/../venv/bin/python"
    "$venv_python" "$script_dir/process.py" --patterns
}

log_telemetry() {
    local action="$1"
    local timestamp
    local telemetry_file="${LOGS_DIR}/telemetry.csv"
    timestamp=$(date +%Y%m%d_%H%M%S)
    if [[ ! -f "$telemetry_file" ]]; then
        echo "timestamp,action" > "$telemetry_file"
    fi
    echo "${timestamp},${action}" >> "$telemetry_file"
}

# The Fog Test constraint: Must be executable and stop with a single keystroke.
record_entry() {
    notify_failed_entries
    get_energy_state
    
    local timestamp
    timestamp=$(date +%Y%m%d_%H%M%S)
    local raw_file="${RAW_DIR}/entry_${timestamp}.txt"
    local capture_interrupted=0
    
    echo ""
    echo "🪞 Shadow Mirror is listening..."
    echo "(Trigger Superwhisper via Option + Space, speak, then press Ctrl+D when finished)"
    
    # Read all input until EOF (Ctrl+D) and save it directly to the raw text file
    trap 'capture_interrupted=1' INT
    cat > "$raw_file" || true
    trap - INT
    
    if [[ ! -s "$raw_file" ]]; then
        echo ""
        echo "No input received. Discarding entry."
        rm -f "$raw_file"
        return
    fi
    
    echo "" # newline after Ctrl+D

    if [[ "$capture_interrupted" -eq 1 ]]; then
        echo "Entry saved as-is."
    fi
    
    if [[ "$SPOONS" == "Red" ]]; then
        echo "Entry secured. Rest now."
    else
        echo "Entry saved. Processing..."
    fi
    
    log_telemetry "entry_recorded"
    
    launch_processing "$timestamp" "$SPOONS"
}

# The Fog Test constraint: Must be simple, fast, and high-contrast
review_entries() {
    get_energy_state
    
    if [[ "$SPOONS" == "Red" ]]; then
        echo "🪞 The mirror is holding everything safely. It will be here when you're rested."
        return
    elif [[ "$SPOONS" == "Yellow" ]]; then
        echo "⚠️ Warning: Limited synthesis insights shown to prevent overload."
        read -n 1 -s -r -p "Press any key to continue..."
        echo ""
    fi
    
    log_telemetry "review_accessed"

    local md_files
    md_files=$(find "$SYNTH_DIR" -type f -name "*.md" 2>/dev/null)
    if [[ -z "$md_files" ]]; then
        echo "No synthesis entries yet."
        return
    fi
    
    local selected_file

    if ! command -v fzf >/dev/null 2>&1; then
        selected_file=$(find "$SYNTH_DIR" -type f -name "*.md" -print0 | xargs -0 ls -t 2>/dev/null | head -n 1)
        if [[ -n "$selected_file" ]]; then
            ${PAGER:-less} "$selected_file"
        fi
        return
    fi

    # Check if bat is installed for syntax highlighted previews, otherwise fallback to cat
    local preview_cmd="cat {}"
    if command -v bat &> /dev/null; then
        preview_cmd="bat --color=always --style=plain {}"
    fi
    
    # Use fzf to select a file based on file contents (pattern recognition)
    # The preview window shows the full synthesis on the right
    selected_file=$(find "$SYNTH_DIR" -type f -name "*.md" | \
        fzf --preview "$preview_cmd" \
            --preview-window=right:70%:wrap \
            --prompt="Search Triggers/Patterns > " \
            --bind "enter:accept" \
            --bind "esc:abort" || true)
            
    if [[ -n "$selected_file" ]]; then
        # If the user selects a file, open it in their preferred editor, or fallback to less
        ${EDITOR:-less} "$selected_file"
    fi
}

if [[ $# -eq 0 ]]; then
    print_usage
    exit 0
fi

case "$1" in
    --entry|-e)
        record_entry
        ;;
    --review|-r)
        review_entries
        ;;
    --patterns|-p)
        show_patterns
        ;;
    --status|-s)
        show_status
        ;;
    --retry)
        retry_failed_entries
        ;;
    --help|-h)
        print_usage
        ;;
    *)
        echo "Unknown option: $1"
        print_usage
        exit 1
        ;;
esac
